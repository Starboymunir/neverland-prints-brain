{% comment %}
  ART DETAIL — API-driven product page.
  Mirrors product-page.liquid's design/classes (styled by neverland.css) so the
  catalog (/pages/art) looks identical to the /products/ pages: frame preview,
  size tiers, room mockup, specs, accordion. Data + dynamic pricing are filled
  in by neverland-catalog.js (assets/neverland-catalog.js), which targets the
  art-* element IDs and injects the room mockup into #art-room-view.
{% endcomment %}

{%- assign api_base = section.settings.api_base | default: 'https://neverland-prints-brain-xvuy.onrender.com' -%}

<meta name="mockup-bg-url" content="{{ 'mockup-wall.jpg' | asset_url }}">

<section class="product-page art-detail-page" data-api-base="{{ api_base }}" id="art-detail">
  <div class="container">

    {%- comment -%} Loading {%- endcomment -%}
    <div class="art-detail__loading" id="art-loading">
      <div class="catalog-loading__spinner" style="width:40px;height:40px;border-width:4px;margin:80px auto;"></div>
    </div>

    {%- comment -%} Content (hidden until loaded) {%- endcomment -%}
    <div id="art-content" style="display:none;">

      <nav class="pp-breadcrumbs" aria-label="Breadcrumb">
        <ol>
          <li><a href="/">Home</a></li>
          <li><a href="/pages/catalog">All Prints</a></li>
          <li aria-current="page" id="art-breadcrumb-title">Loading…</li>
        </ol>
      </nav>

      <div class="product-layout">

        {%- comment -%} ═══ Gallery ═══ {%- endcomment -%}
        <div class="product-gallery">
          <div class="product-gallery__main">
            <div class="frame-preview" id="frame-preview" data-frame="none">
              <div class="frame-preview__mat" id="frame-mat">
                <div class="frame-preview__img-wrap">
                  <img id="art-image" src="" srcset="" sizes="(max-width: 768px) 95vw, 50vw" alt="" loading="eager" fetchpriority="high">
                  <img src="{{ 'watermark-1.png' | asset_url }}" alt="" class="pp-watermark" aria-hidden="true">
                </div>
              </div>
            </div>
            <button class="pp-zoom-btn" id="pp-zoom-btn" type="button" aria-label="Zoom image">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/><path d="M11 8v6M8 11h6"/></svg>
            </button>
          </div>

          {%- comment -%} Frame style selector — shown when Framed {%- endcomment -%}
          <div class="frame-selector" id="frame-selector" style="display:none">
            <span class="frame-selector__label">Preview Frame Style</span>
            <div class="frame-selector__options">
              <button type="button" class="frame-option is-active" data-frame="black" title="Black Frame">
                <span class="frame-option__swatch frame-option__swatch--black"></span>
                <span class="frame-option__name">Black</span>
              </button>
              <button type="button" class="frame-option" data-frame="white" title="White Frame">
                <span class="frame-option__swatch frame-option__swatch--white"></span>
                <span class="frame-option__name">White</span>
              </button>
              <button type="button" class="frame-option" data-frame="natural" title="Natural Wood Frame">
                <span class="frame-option__swatch frame-option__swatch--natural"></span>
                <span class="frame-option__name">Natural</span>
              </button>
              <button type="button" class="frame-option" data-frame="walnut" title="Walnut Frame">
                <span class="frame-option__swatch frame-option__swatch--walnut"></span>
                <span class="frame-option__name">Walnut</span>
              </button>
            </div>
          </div>
        </div>

        {%- comment -%} ═══ Details ═══ {%- endcomment -%}
        <div class="product-details">
          <div class="product-details__artist" id="art-artist"></div>
          <h1 class="product-details__title" id="art-title"></h1>

          <div class="product-details__price">
            <span class="product-details__price-current" id="art-price"></span>
            <span class="product-details__price-compare" id="art-compare-price"></span>
          </div>

          {%- comment -%} Size selector (populated by JS) {%- endcomment -%}
          <div class="variant-selector" id="art-variants-section" style="display:none">
            <div class="variant-selector__label">Size <span id="art-size-display" style="color:var(--text-muted);font-weight:400;text-transform:none;letter-spacing:0;"></span></div>
            <div class="variant-selector__options" id="art-variant-options"></div>
          </div>

          {%- comment -%} Frame selector {%- endcomment -%}
          <div class="variant-selector" id="art-frame-section">
            <div class="variant-selector__label">Frame <span id="art-frame-display" style="color:var(--text-muted);font-weight:400;text-transform:none;letter-spacing:0;">Unframed</span></div>
            <div class="variant-selector__options" id="art-frame-options">
              <button type="button" class="variant-option is-selected" data-frame="unframed">Unframed</button>
              <button type="button" class="variant-option" data-frame="framed">Framed</button>
            </div>
          </div>

          {%- comment -%} Add to Cart {%- endcomment -%}
          <button type="button" class="add-to-cart" id="art-add-to-cart">
            Add to Cart — <span id="art-cart-price">$33.99</span>
          </button>

          <div class="art-detail__feedback" id="art-feedback" style="display:none;">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 6 9 17l-5-5"/></svg>
            <span>Added to cart!</span>
            <a href="/cart">View Cart</a>
          </div>

          {%- comment -%} Trust badges {%- endcomment -%}
          <div class="product-trust">
            <div class="product-trust__item">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><path d="m9 12 2 2 4-4"/></svg>
              <span>Satisfaction Guaranteed</span>
            </div>
            <div class="product-trust__item">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="1" y="3" width="15" height="13"/><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>
              <span>Worldwide Shipping</span>
            </div>
            <div class="product-trust__item">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
              <span>Ships in 3–7 days</span>
            </div>
          </div>

          {%- comment -%} Room mockup — injected by JS into #art-room-view {%- endcomment -%}
          <div id="art-room-view"></div>

          {%- comment -%} Print Specs — injected by JS {%- endcomment -%}
          <div class="product-meta" id="art-meta"></div>

          {%- comment -%} Accordion {%- endcomment -%}
          <div class="pp-accordion" id="pp-accordion">
            <div class="pp-accordion__item">
              <button class="pp-accordion__trigger is-open" type="button">
                <span>About This Print</span>
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m6 9 6 6 6-6"/></svg>
              </button>
              <div class="pp-accordion__body is-open">
                <div class="pp-accordion__text" id="art-description"></div>
              </div>
            </div>
            <div class="pp-accordion__item">
              <button class="pp-accordion__trigger" type="button">
                <span>Materials &amp; Quality</span>
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m6 9 6 6 6-6"/></svg>
              </button>
              <div class="pp-accordion__body">
                <div class="pp-accordion__text">
                  <ul>
                    <li>Premium 310gsm cotton-rag archival paper</li>
                    <li>Giclée printing with pigment-based inks</li>
                    <li>Rated 200+ years lightfastness</li>
                    <li>Vibrant, accurate colour reproduction</li>
                    <li>Textured matte finish</li>
                  </ul>
                </div>
              </div>
            </div>
            <div class="pp-accordion__item">
              <button class="pp-accordion__trigger" type="button">
                <span>Shipping &amp; Returns</span>
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m6 9 6 6 6-6"/></svg>
              </button>
              <div class="pp-accordion__body">
                <div class="pp-accordion__text">
                  <p><strong>Production</strong> — 1–3 business days for paper prints; up to 5 days for framed pieces.</p>
                  <p><strong>Shipping</strong> — Rates calculated at checkout. Ships flat in rigid protective packaging.</p>
                  <p><strong>30-day satisfaction guarantee</strong> — not happy? Contact us within 30 days for a replacement or refund.</p>
                  <p>Full details: <a href="/pages/shipping">Shipping</a> · <a href="/pages/returns">Returns &amp; Refunds</a></p>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>

      {%- comment -%} Similar Artworks {%- endcomment -%}
      <div class="pp-related" id="art-similar" style="display:none;">
        <div class="pp-related__head">
          <h2 class="pp-related__title">You May Also Like</h2>
          <a href="/pages/catalog" class="pp-related__link" id="art-similar-link">
            View All
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </a>
        </div>
        <div class="pp-related__grid" id="art-similar-grid"></div>
      </div>
    </div>

    {%- comment -%} Not Found {%- endcomment -%}
    <div class="empty-state" id="art-not-found" style="display:none;">
      <h2>Artwork Not Found</h2>
      <p>This artwork may have been removed or the link is invalid.</p>
      <a href="/pages/catalog" class="btn btn--primary"><span>Browse All Prints</span></a>
    </div>

    {%- comment -%} Lightbox {%- endcomment -%}
    <div class="pp-lightbox" id="pp-lightbox">
      <div class="pp-lightbox__overlay" id="pp-lightbox-close"></div>
      <div class="pp-lightbox__content">
        <img id="pp-lightbox-img" src="" alt="">
        <button class="pp-lightbox__close" type="button" aria-label="Close">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 6 6 18M6 6l12 12"/></svg>
        </button>
      </div>
    </div>

  </div>
</section>

<style>
  /* Layout/gallery/tiers/mockup/specs/trust are styled by neverland.css
     (product-layout, frame-preview, variant-selector, room-preview, product-meta,
     product-trust, add-to-cart). These rules cover the few extras not in it. */
  .art-detail__loading { min-height: 400px; display: flex; align-items: center; justify-content: center; }
  .catalog-loading__spinner { border: 4px solid var(--border, #e8e8e8); border-top-color: var(--text, #111); border-radius: 50%; animation: pp-spin 0.8s linear infinite; }
  @keyframes pp-spin { to { transform: rotate(360deg); } }

  .art-detail__feedback { display: flex; align-items: center; gap: 8px; padding: 12px 16px; background: #f0fdf4; border: 1px solid #86efac; border-radius: 8px; color: #166534; margin-top: 16px; font-size: 0.9rem; }
  .art-detail__feedback a { margin-left: auto; font-weight: 600; color: #166534; text-decoration: underline; }

  .pp-breadcrumbs ol { list-style: none; display: flex; flex-wrap: wrap; gap: 8px; padding: 0; margin: 0 0 24px; font-size: 0.78rem; color: var(--text-muted, #999); }
  .pp-breadcrumbs li { display: flex; align-items: center; gap: 8px; }
  .pp-breadcrumbs li + li::before { content: "/"; color: var(--border, #ddd); }
  .pp-breadcrumbs a { color: var(--text-sec, #555); text-decoration: none; }
  .pp-breadcrumbs a:hover { color: var(--text, #111); }

  .product-gallery__main { position: relative; }
  .pp-watermark { position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%); width: 40%; max-width: 220px; opacity: 0.13; pointer-events: none; user-select: none; z-index: 2; }
  .pp-zoom-btn { position: absolute; bottom: 16px; right: 16px; width: 42px; height: 42px; border-radius: 50%; background: rgba(255,255,255,0.92); border: 1px solid var(--border, #e8e8e8); color: var(--text, #111); display: flex; align-items: center; justify-content: center; cursor: pointer; box-shadow: 0 2px 8px rgba(0,0,0,0.12); transition: transform 0.2s; z-index: 3; }
  .pp-zoom-btn:hover { transform: scale(1.08); }

  /* Accordion (neverland-catalog.js toggles .is-open on trigger + body) */
  .pp-accordion { margin-top: 28px; }
  .pp-accordion__item { border-bottom: 1px solid var(--border, #e8e8e8); }
  .pp-accordion__trigger { width: 100%; display: flex; justify-content: space-between; align-items: center; gap: 12px; padding: 16px 0; background: none; border: 0; cursor: pointer; font-family: inherit; font-size: 0.95rem; font-weight: 500; color: var(--text, #111); text-align: left; }
  .pp-accordion__trigger svg { transition: transform 0.3s; flex-shrink: 0; }
  .pp-accordion__trigger.is-open svg { transform: rotate(180deg); }
  .pp-accordion__body { max-height: 0; overflow: hidden; transition: max-height 0.35s ease; }
  .pp-accordion__body.is-open { max-height: 900px; }
  .pp-accordion__text { padding: 0 0 18px; color: var(--text-sec, #555); font-size: 0.9rem; line-height: 1.7; }
  .pp-accordion__text ul { margin: 0; padding-left: 18px; }
  .pp-accordion__text li, .pp-accordion__text p { margin: 0 0 8px; }

  /* Related */
  .pp-related { margin-top: 64px; padding-bottom: 48px; }
  .pp-related__head { display: flex; justify-content: space-between; align-items: center; margin-bottom: 24px; }
  .pp-related__title { font-family: var(--font-display, 'Inter', sans-serif); font-size: 1.4rem; font-weight: 600; margin: 0; }
  .pp-related__link { display: inline-flex; align-items: center; gap: 6px; font-size: 0.76rem; letter-spacing: 0.1em; text-transform: uppercase; color: var(--text, #111); text-decoration: none; }
  .pp-related__link:hover { gap: 10px; }
  .pp-related__grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 24px; }
  @media (max-width: 900px) { .pp-related__grid { grid-template-columns: repeat(2, 1fr); } }

  /* Lightbox */
  .pp-lightbox { display: none; position: fixed; inset: 0; z-index: 9999; align-items: center; justify-content: center; }
  .pp-lightbox.is-open { display: flex; }
  .pp-lightbox__overlay { position: absolute; inset: 0; background: rgba(0,0,0,0.92); }
  .pp-lightbox__content { position: relative; z-index: 1; }
  .pp-lightbox__content img { max-width: 90vw; max-height: 88vh; object-fit: contain; display: block; }
  .pp-lightbox__close { position: absolute; top: -44px; right: 0; background: none; border: 0; color: #fff; cursor: pointer; }
</style>

{% schema %}
{
  "name": "Art Detail",
  "settings": [
    {
      "type": "text",
      "id": "api_base",
      "label": "API Base URL",
      "default": "https://neverland-prints-brain-xvuy.onrender.com"
    }
  ],
  "presets": [{ "name": "Art Detail" }]
}
{% endschema %}
