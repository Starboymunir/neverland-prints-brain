{% comment %} MARQUEE — Infinite scrolling trust ticker {% endcomment %}

<section class="marquee" data-animate="fade-up">
  <div class="marquee__track">
    {%- for i in (1..3) -%}
      <div class="marquee__group">
        <span class="marquee__item">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
          Museum-Quality Printing
        </span>
        <span class="marquee__dot"></span>
        <span class="marquee__item">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/></svg>
          90,000+ Artworks
        </span>
        <span class="marquee__dot"></span>
        <span class="marquee__item">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
          Worldwide Delivery
        </span>
        <span class="marquee__dot"></span>
        <span class="marquee__item">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 2L2 7l10 5 10-5-10-5z"/><path d="M2 17l10 5 10-5"/><path d="M2 12l10 5 10-5"/></svg>
          Archival Grade Paper
        </span>
        <span class="marquee__dot"></span>
        <span class="marquee__item">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 12 20 22 4 22 4 12"/><rect x="2" y="7" width="20" height="5"/><line x1="12" y1="22" x2="12" y2="7"/><path d="M12 7H7.5a2.5 2.5 0 0 1 0-5C11 2 12 7 12 7z"/><path d="M12 7h4.5a2.5 2.5 0 0 0 0-5C13 2 12 7 12 7z"/></svg>
          200+ Year Lightfastness
        </span>
        <span class="marquee__dot"></span>
        <span class="marquee__item">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/><polyline points="3.27 6.96 12 12.01 20.73 6.96"/><line x1="12" y1="22.08" x2="12" y2="12"/></svg>
          Ready to Hang
        </span>
        <span class="marquee__dot"></span>
      </div>
    {%- endfor -%}
  </div>
</section>

{% schema %}
{
  "name": "Marquee Ticker",
  "settings": [],
  "presets": [{ "name": "Marquee Ticker" }]
}
{% endschema %}
