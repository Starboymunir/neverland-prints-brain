{% comment %}
  WALL MOCKUP — Photorealistic room scenes with dynamic art overlay
  Uses DALL-E 3 generated room images with CSS-positioned art placeholders
{% endcomment %}

<section class="section wall-mockup-section">
  <div class="wm-container">
    <div class="wm-header">
      <span class="wm-eyebrow">{{ section.settings.eyebrow }}</span>
      <h2 class="wm-title">{{ section.settings.title }}</h2>
      <p class="wm-sub">{{ section.settings.subtitle }}</p>
    </div>

    <div class="wm-grid">
      <!-- Room 1: Living Room — Large landscape frame above sofa -->
      <div class="wm-room wm-room--wide">
        <div class="wm-scene">
          <img src="{{ 'mockup-living-room.jpg' | asset_url }}" alt="Modern living room with framed art above sofa" class="wm-bg" loading="lazy" width="1792" height="1024">
          <div class="wm-frame wm-frame--living" id="wm-art-1">
            <div class="wm-shimmer"></div>
          </div>
        </div>
        <div class="wm-caption" id="wm-cap-1">
          <span class="wm-cap-title">Loading artwork…</span>
          <span class="wm-cap-meta">Large Framed Print</span>
        </div>
      </div>

      <!-- Room 2: Bedroom — Portrait frame above nightstand -->
      <div class="wm-room">
        <div class="wm-scene">
          <img src="{{ 'mockup-bedroom.jpg' | asset_url }}" alt="Serene bedroom with framed art above nightstand" class="wm-bg" loading="lazy" width="1792" height="1024">
          <div class="wm-frame wm-frame--bedroom" id="wm-art-2">
            <div class="wm-shimmer"></div>
          </div>
        </div>
        <div class="wm-caption" id="wm-cap-2">
          <span class="wm-cap-title">Loading artwork…</span>
          <span class="wm-cap-meta">Medium Framed Print</span>
        </div>
      </div>

      <!-- Room 3: Gallery Wall — Three frames in a row -->
      <div class="wm-room">
        <div class="wm-scene">
          <img src="{{ 'mockup-gallery-wall.jpg' | asset_url }}" alt="Gallery wall with three framed prints" class="wm-bg" loading="lazy" width="1792" height="1024">
          <div class="wm-frame wm-frame--gal1" id="wm-art-3">
            <div class="wm-shimmer"></div>
          </div>
          <div class="wm-frame wm-frame--gal2" id="wm-art-4">
            <div class="wm-shimmer"></div>
          </div>
          <div class="wm-frame wm-frame--gal3" id="wm-art-5">
            <div class="wm-shimmer"></div>
          </div>
        </div>
        <div class="wm-caption wm-caption--dark" id="wm-cap-3">
          <span class="wm-cap-title">Gallery Wall</span>
          <span class="wm-cap-meta">3 Curated Prints</span>
        </div>
      </div>
    </div>

    <div class="wm-cta-row">
      <a href="/pages/catalog" class="btn btn--primary btn--large wm-cta">
        <span>{{ section.settings.cta_text }}</span>
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
      </a>
    </div>
  </div>
</section>

<style>
  /* ── Section ── */
  .wall-mockup-section { padding: 80px 0; background: var(--bg-cream, #faf8f4); }
  .wm-container { max-width: 1200px; margin: 0 auto; padding: 0 20px; }

  /* ── Header ── */
  .wm-header { text-align: center; margin-bottom: 48px; }
  .wm-eyebrow {
    display: block; font-size: .72rem; font-weight: 600;
    letter-spacing: .14em; text-transform: uppercase;
    color: var(--gold, #b49b64); margin-bottom: 10px;
  }
  .wm-title {
    font-family: var(--font-display, Georgia, serif);
    font-size: clamp(1.8rem, 4vw, 2.8rem); font-weight: 500;
    color: var(--text-dark, #1a1a2e); margin: 0 0 12px;
  }
  .wm-sub {
    font-size: 1rem; color: rgba(26,26,46,.6);
    max-width: 560px; margin: 0 auto; line-height: 1.6;
  }

  /* ── Grid ── */
  .wm-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 24px; margin-bottom: 40px; }
  .wm-room { border-radius: 12px; overflow: hidden; background: #e8e2d8; box-shadow: 0 4px 24px rgba(0,0,0,.08); }
  .wm-room--wide { grid-column: 1 / -1; }

  /* ── Scene ── */
  .wm-scene { position: relative; width: 100%; overflow: hidden; line-height: 0; }
  .wm-bg { display: block; width: 100%; height: auto; }

  /* ── Frame overlay (positioned over the white mat inside each frame in the photo) ── */
  .wm-frame {
    position: absolute; overflow: hidden; z-index: 2;
    border: 2px solid rgba(58,42,26,.25);
    box-shadow: inset 0 0 6px rgba(0,0,0,.15);
    background: linear-gradient(135deg, #e8e0d0, #d8d0c0);
  }
  .wm-frame img {
    width: 100%; height: 100%; object-fit: cover; display: block;
  }

  /* Living room frame — large landscape above sofa centre */
  .wm-frame--living { top: 14%; left: 29.5%; width: 24%; height: 38%; }

  /* Bedroom frame — portrait above nightstand, slightly left of centre */
  .wm-frame--bedroom { top: 9%; left: 32%; width: 19%; height: 44%; }

  /* Gallery wall — 3 equal frames in a horizontal row */
  .wm-frame--gal1 { top: 15%; left: 13.5%; width: 15%; height: 34%; }
  .wm-frame--gal2 { top: 15%; left: 35.5%; width: 15%; height: 34%; }
  .wm-frame--gal3 { top: 15%; left: 57.5%; width: 15%; height: 34%; }

  /* Shimmer placeholder */
  .wm-shimmer {
    width: 100%; height: 100%;
    background: linear-gradient(90deg, rgba(255,255,255,.08) 25%, rgba(255,255,255,.22) 50%, rgba(255,255,255,.08) 75%);
    background-size: 200% 100%;
    animation: wmShim 1.5s ease-in-out infinite;
  }
  @keyframes wmShim {
    0%   { background-position: 200% 0; }
    100% { background-position: -200% 0; }
  }

  /* ── Caption bar ── */
  .wm-caption {
    padding: 16px 20px; display: flex; justify-content: space-between;
    align-items: center; background: #fff; border-top: 1px solid rgba(0,0,0,.06);
  }
  .wm-cap-title {
    font-family: var(--font-display, Georgia, serif);
    font-size: .95rem; font-weight: 500; color: var(--text-dark, #1a1a2e);
    white-space: nowrap; overflow: hidden; text-overflow: ellipsis; max-width: 68%;
  }
  .wm-cap-title a { color: inherit; text-decoration: none; }
  .wm-cap-title a:hover { text-decoration: underline; }
  .wm-cap-meta {
    font-size: .78rem; color: rgba(26,26,46,.5);
    text-transform: uppercase; letter-spacing: .06em; white-space: nowrap;
  }
  .wm-caption--dark { background: #1a1a2e; border-top-color: rgba(255,255,255,.1); }
  .wm-caption--dark .wm-cap-title { color: #fff; }
  .wm-caption--dark .wm-cap-meta { color: rgba(255,255,255,.5); }

  /* ── CTA ── */
  .wm-cta-row { text-align: center; margin-top: 16px; }
  .wm-cta { gap: 8px; }

  /* ── Mobile ── */
  @media (max-width: 768px) {
    .wall-mockup-section { padding: 48px 0; }
    .wm-grid { grid-template-columns: 1fr; }
    .wm-room--wide { grid-column: auto; }
    .wm-header { margin-bottom: 32px; }
  }
</style>

<script>
(function() {
  var API = 'https://neverland-prints-brain.onrender.com';

  function load() {
    fetch(API + '/api/storefront/catalog?sort=random&per_page=5')
      .then(function(r) { return r.ok ? r.json() : Promise.reject('API ' + r.status); })
      .then(function(d) {
        var items = d.items || [];
        if (!items.length) return;
        fill('wm-art-1', 'wm-cap-1', items[0], 's800');
        fill('wm-art-2', 'wm-cap-2', items[1] || items[0], 's600');
        fill('wm-art-3', null, items[2] || items[0], 's400');
        fill('wm-art-4', null, items[3] || items[1] || items[0], 's400');
        fill('wm-art-5', null, items[4] || items[2] || items[0], 's400');
        /* Update gallery caption with count */
        if (items.length >= 3) {
          var gc = document.getElementById('wm-cap-3');
          if (gc) {
            var t = gc.querySelector('.wm-cap-title');
            if (t) t.textContent = 'Gallery Wall';
          }
        }
      })
      .catch(function(e) { console.warn('Wall mockup:', e); });
  }

  function fill(artId, capId, item, size) {
    var el = document.getElementById(artId);
    if (!el || !item) return;
    var url = (item.imageSrcset && item.imageSrcset[size]) || item.image;
    var img = new Image();
    img.onload = function() {
      el.innerHTML = '';
      el.style.background = 'none';
      img.style.cssText = 'width:100%;height:100%;object-fit:cover;display:block;';
      el.appendChild(img);
    };
    img.alt = item.title || 'Art print';
    img.loading = 'lazy';
    img.src = url;

    if (capId) {
      var cap = document.getElementById(capId);
      if (cap) {
        var t = cap.querySelector('.wm-cap-title');
        if (t) t.innerHTML = '<a href="/pages/art?id=' + item.id + '">' +
          (item.title || 'Untitled') + '</a>';
      }
    }
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', load);
  } else {
    load();
  }
})();
</script>

{% schema %}
{
  "name": "Wall Mockup",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow text", "default": "Visualise Your Space" },
    { "type": "text", "id": "title", "label": "Heading", "default": "See It On Your Wall" },
    { "type": "text", "id": "subtitle", "label": "Subtitle", "default": "Every piece, framed or unframed, designed to transform your space." },
    { "type": "text", "id": "cta_text", "label": "Button text", "default": "Shop Framed Prints" }
  ],
  "presets": [{ "name": "Wall Mockup" }]
}
{% endschema %}
